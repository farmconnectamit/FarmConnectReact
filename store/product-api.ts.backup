import { createApi, fetchBaseQuery } from '@reduxjs/toolkit/query/react';
import { getAuthToken, setAuthToken } from '../src/utils/auth';

// Define the base URL for your Django API
const baseUrl = 'http://10.0.2.2:8000/api/v1';

// Create a custom fetchBaseQuery with token refresh logic
const baseQuery = fetchBaseQuery({
  baseUrl: baseUrl,
  prepareHeaders: async (headers, { getState }) => {
    // Add auth token if available from NativeKeyStore
    try {
      const token = await getAuthToken();
      if (token) {
        headers.set('authorization', `Bearer ${token}`);
      }
    } catch (error) {
      console.error('Error retrieving token from NativeKeyStore:', error);
    }
    return headers;
  },
});

// Custom fetchBaseQuery with refresh token logic
const baseQueryWithReauth = async (args: any, api: any, extraOptions: any) => {
  let result = await baseQuery(args, api, extraOptions);
  
  // If the response has a 401 Unauthorized error, try to refresh the token
  if (result?.error?.status === 401) {
    console.log('Token expired, attempting to refresh...');
    
    // Here you would implement your token refresh logic
    // For now, we'll just clear the tokens and let the app redirect to login
    try {
      // Clear existing tokens
      await clearTokens();
      
      // You might want to navigate to login screen here
      // This would require access to navigation in a React component context
      
      // Return an error so that the calling code can handle it appropriately
      return result;
    } catch (refreshError) {
      console.error('Failed to refresh token:', refreshError);
    }
  }
  
  return result;
};

export const productsApi = createApi({
  reducerPath: 'productsApi',
  baseQuery: baseQueryWithReauth,
  tagTypes: ['Product', 'Merchant', 'Farm', 'Category'],
  endpoints: (builder) => ({
    getAllProducts: builder.query({
      query: ({ search = '', category = null, ordering = '-created_at' } = {}) => {
        const params = new URLSearchParams();
        if (search) params.append('search', search);
        if (category) params.append('category', category);
        params.append('ordering', ordering);
        
        return {
          url: 'products/',
          method: 'GET',
          params,
        };
      },
      providesTags: ['Product'],
    }),
    getProductById: builder.query({
      query: (id) => `products/${id}/`,
      providesTags: (result, error, id) => [{ type: 'Product', id }],
    }),
    getProductsByMerchantId: builder.query({
      query: (merchantId) => {
        return {
          url: `products/?merchant=${merchantId}`,
          method: 'GET',
        };
      },
      providesTags: ['Product'],
    }),
    getAllMerchants: builder.query({
      query: () => {
        return {
          url: 'merchants/',
          method: 'GET',
        };
      },
      providesTags: ['Merchant'],
    }),
    getMerchantById: builder.query({
      query: (id) => `merchants/${id}/`,
      providesTags: (result, error, id) => [{ type: 'Merchant', id }],
    }),
    getAllFarms: builder.query({
      query: () => {
        return {
          url: 'farms/',
          method: 'GET',
        };
      },
      providesTags: ['Farm'],
    }),
    getFarmById: builder.query({
      query: (id) => `farms/${id}/`,
      providesTags: (result, error, id) => [{ type: 'Farm', id }],
    }),
    getAllCategories: builder.query({
      query: () => {
        return {
          url: 'categories/',
          method: 'GET',
        };
      },
      providesTags: ['Category'],
    }),
    getCategoryById: builder.query({
      query: (id) => `categories/${id}/`,
      providesTags: (result, error, id) => [{ type: 'Category', id }],
    }),
    createProduct: builder.mutation({
      query: (newProduct) => ({
        url: 'products/',
        method: 'POST',
        body: newProduct,
      }),
      invalidatesTags: ['Product'],
    }),
    updateProduct: builder.mutation({
      query: ({ id, ...patch }) => ({
        url: `products/${id}/`,
        method: 'PUT',
        body: patch,
      }),
      invalidatesTags: (result, error, { id }) => [{ type: 'Product', id }],
    }),
    deleteProduct: builder.mutation({
      query: (id) => ({
        url: `products/${id}/`,
        method: 'DELETE',
      }),
      invalidatesTags: (result, error, id) => [{ type: 'Product', id }],
    }),
    createMerchant: builder.mutation({
      query: (newMerchant) => ({
        url: 'merchants/',
        method: 'POST',
        body: newMerchant,
      }),
      invalidatesTags: ['Merchant'],
    }),
    updateMerchant: builder.mutation({
      query: ({ id, ...patch }) => ({
        url: `merchants/${id}/`,
        method: 'PUT',
        body: patch,
      }),
      invalidatesTags: (result, error, { id }) => [{ type: 'Merchant', id }],
    }),
    deleteMerchant: builder.mutation({
      query: (id) => ({
        url: `merchants/${id}/`,
        method: 'DELETE',
      }),
      invalidatesTags: (result, error, id) => [{ type: 'Merchant', id }],
    }),
  }),
});

// Export hooks for usage in components
export const {
  useGetAllProductsQuery,
  useGetProductByIdQuery,
  useGetProductsByMerchantIdQuery,
  useGetAllMerchantsQuery,
  useGetMerchantByIdQuery,
  useGetAllFarmsQuery,
  useGetFarmByIdQuery,
  useGetAllCategoriesQuery,
  useGetCategoryByIdQuery,
  useCreateProductMutation,
  useUpdateProductMutation,
  useDeleteProductMutation,
  useCreateMerchantMutation,
  useUpdateMerchantMutation,
  useDeleteMerchantMutation,
} = productsApi;